---
import { LOCALES, localizePath, DEFAULT_LOCALE, type Locale } from '../i18n/config';
import { BUSINESS } from '../data/business';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  path: string;
  image?: string;
  imageAlt?: string;
  jsonLd?: object[];
}

const { title, description, locale, path, image = '/og/default.png', imageAlt, jsonLd = [] } = Astro.props;
const ogImageAlt = imageAlt ?? `${BUSINESS.name} — ${title}`;
// Twitter @handle from the X profile URL (…/buckbike → @buckbike).
const twitterHandle = '@' + BUSINESS.socials.x.replace(/\/+$/, '').split('/').pop();

const site = (Astro.site?.toString() ?? 'https://buckbike.com').replace(/\/$/, '');
const canonical = site + localizePath(path, locale);
const ogImage = image.startsWith('http') ? image : site + image;

const OG_LOCALES: Record<Locale, string> = {
  en: 'en_US',
  vi: 'vi_VN',
  ru: 'ru_RU',
  ja: 'ja_JP',
  ko: 'ko_KR',
  zh: 'zh_CN',
  hi: 'hi_IN',
};
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="canonical" href={canonical} />

{
  LOCALES.map((l) => (
    <link rel="alternate" hreflang={l} href={site + localizePath(path, l)} />
  ))
}
<link rel="alternate" hreflang="x-default" href={site + localizePath(path, DEFAULT_LOCALE)} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="BuckBike" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:locale" content={OG_LOCALES[locale]} />
{
  LOCALES.filter((l) => l !== locale).map((l) => (
    <meta property="og:locale:alternate" content={OG_LOCALES[l]} />
  ))
}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

{jsonLd.map((obj) => <script type="application/ld+json" is:inline set:html={JSON.stringify(obj)} />)}
