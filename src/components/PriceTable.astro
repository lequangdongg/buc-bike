---
import { BIKES } from '../data/fleet';
import { PRICING } from '../data/pricing';
import { useTranslations } from '../i18n';
import type { Locale } from '../i18n/config';
import type { Period } from '../data/pricing';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = await useTranslations(locale);

const periods: Period[] = ['daily', 'weekly', 'monthly'];
const suffix: Record<Period, string> = {
  daily: t('price.per_day'),
  weekly: t('price.per_week'),
  monthly: t('price.per_month'),
};
---

<div data-price-table data-suffix={JSON.stringify(suffix)} data-locale={locale}>
  <div role="tablist" aria-label={t('price.kicker')} class="mb-10 inline-flex rounded-full border border-(--line) p-1">
    {
      periods.map((p, i) => (
        <button
          role="tab"
          type="button"
          data-period={p}
          aria-selected={i === 0 ? 'true' : 'false'}
          class="rounded-full px-5 py-2 text-sm font-medium text-(--muted) transition aria-[selected=true]:bg-accent aria-[selected=true]:text-(--color-accent-ink)"
        >
          {t(`price.period.${p}`)}
          {p === 'weekly' ? ` ★` : ''}
        </button>
      ))
    }
  </div>

  <div class="grid gap-5 md:grid-cols-3" data-reveal>
    {
      BIKES.map((bike, i) => (
        <div
          data-reveal-item
          class:list={[
            'relative rounded-card border bg-(--card) p-7',
            i === 1 ? 'border-accent' : 'border-(--line)',
          ]}
        >
          {i === 1 && (
            <span class="absolute right-6 top-6 rounded-full bg-accent px-3 py-1 text-xs font-semibold text-(--color-accent-ink)">
              {t('price.most_popular')}
            </span>
          )}
          <h3 class="font-display text-lg font-bold">{bike.name}</h3>
          <p class="mt-1 text-sm text-(--muted)">{bike.rangeKm} km · {bike.topSpeedKmh} km/h</p>
          <p class="mt-6 font-display text-4xl font-bold text-accent" data-price-cell={JSON.stringify(PRICING[bike.id])}>
            {new Intl.NumberFormat('vi-VN').format(PRICING[bike.id].daily)} ₫
          </p>
          <p class="mt-1 text-sm text-(--muted)" data-price-suffix>{suffix.daily}</p>
        </div>
      ))
    }
  </div>
</div>

<script>
  import { animate } from 'motion';
  import { formatVnd } from '../data/pricing';

  function wirePriceTable() {
    const table = document.querySelector<HTMLElement>('[data-price-table]');
    if (!table) return;
    const suffix = JSON.parse(table.dataset.suffix || '{}') as Record<string, string>;
    const tabs = table.querySelectorAll<HTMLButtonElement>('[role=tab]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const period = tab.dataset.period!;
        tabs.forEach((other) =>
          other.setAttribute('aria-selected', String(other === tab)),
        );

        table.querySelectorAll<HTMLElement>('[data-price-cell]').forEach((cell) => {
          const prices = JSON.parse(cell.dataset.priceCell!) as Record<string, number>;
          cell.textContent = formatVnd(prices[period]);
          animate(
            cell,
            { opacity: [0.2, 1], transform: ['translateY(8px)', 'translateY(0)'] },
            { duration: 0.35, ease: [0.16, 1, 0.3, 1] },
          );
        });
        table.querySelectorAll<HTMLElement>('[data-price-suffix]').forEach((el) => {
          el.textContent = suffix[period];
        });
      });
    });
  }

  document.addEventListener('astro:page-load', wirePriceTable);
</script>
