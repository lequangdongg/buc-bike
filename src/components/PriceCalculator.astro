---
import { DAILY_RATE, OVER_3_DAYS_RATE, WEEKLY_RATE } from '../data/pricing';
import { useTranslations } from '../i18n';
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = await useTranslations(locale);
---

<div
  data-calc
  data-daily={DAILY_RATE}
  data-over3={OVER_3_DAYS_RATE}
  data-weekly={WEEKLY_RATE}
  data-contact={t('price.contact_us')}
  data-perday={t('price.per_day')}
  data-day={t('price.calc.day')}
  data-days={t('price.calc.days')}
  class="rounded-card border border-(--line) bg-(--card) p-6 sm:p-8"
>
  <h3 class="font-display text-2xl font-bold">{t('price.calc.heading')}</h3>

  <div class="mt-6">
    <div class="flex items-baseline justify-between">
      <label for="calc-days" class="text-sm text-(--muted)">{t('price.calc.days_label')}</label>
      <span class="font-display text-xl font-bold tabular-nums">
        <span data-calc-days>3</span>
        <span data-calc-unit class="ml-1 text-sm font-normal text-(--muted)">{t('price.calc.days')}</span>
      </span>
    </div>
    <input
      id="calc-days"
      type="range"
      min="1"
      max="30"
      value="3"
      data-calc-range
      class="mt-3 h-2 w-full cursor-pointer appearance-none rounded-full bg-(--card-2) accent-accent"
    />
    <div class="mt-1 flex justify-between text-xs text-(--muted)"><span>1</span><span>30+</span></div>
  </div>

  <div class="mt-6 flex flex-wrap items-end justify-between gap-3 border-t border-(--line) pt-6">
    <div>
      <p class="text-sm text-(--muted)">{t('price.calc.total_label')}</p>
      <p data-calc-total class="font-display text-4xl font-bold tabular-nums text-(--accent-text)">—</p>
    </div>
    <p data-calc-rate class="text-sm text-(--muted)"></p>
  </div>
</div>

<script>
  function initCalc() {
    document.querySelectorAll<HTMLElement>('[data-calc]').forEach((el) => {
      const range = el.querySelector<HTMLInputElement>('[data-calc-range]');
      if (!range || range.dataset.bound) return;
      range.dataset.bound = '1';

      const daily = Number(el.dataset.daily);
      const over3 = Number(el.dataset.over3);
      const weekly = Number(el.dataset.weekly);
      const fmt = (n: number) => new Intl.NumberFormat('vi-VN').format(n) + ' ₫';
      const rateFor = (d: number) => (d <= 3 ? daily : d < 7 ? over3 : weekly);

      const daysEl = el.querySelector('[data-calc-days]');
      const unitEl = el.querySelector('[data-calc-unit]');
      const totalEl = el.querySelector('[data-calc-total]');
      const rateEl = el.querySelector('[data-calc-rate]');

      const update = () => {
        const d = Number(range.value);
        if (daysEl) daysEl.textContent = String(d);
        if (unitEl) unitEl.textContent = d > 1 ? el.dataset.days! : el.dataset.day!;
        if (d >= 30) {
          if (totalEl) totalEl.textContent = el.dataset.contact!;
          if (rateEl) rateEl.textContent = '';
        } else {
          const r = rateFor(d);
          if (totalEl) totalEl.textContent = fmt(r * d);
          if (rateEl) rateEl.textContent = fmt(r) + el.dataset.perday!;
        }
      };
      range.addEventListener('input', update);
      update();
    });
  }
  document.addEventListener('astro:page-load', initCalc);
</script>
