---
import Base from '../../layouts/Base.astro';
import SectionReveal from '../SectionReveal.astro';
import { useTranslations } from '../../i18n';
import { localizePath, type Locale } from '../../i18n/config';
import { buildProductsJsonLd } from '../../lib/seo';
import { DAILY_RATE, OVER_3_DAYS_RATE, WEEKLY_RATE, formatVnd } from '../../data/pricing';
import { BUSINESS } from '../../data/business';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = await useTranslations(locale);
const link = (p: string) => localizePath(p, locale);

const plans = t('price.plans', { returnObjects: true }) as { name: string; note: string }[];
// 4 tiers: 1–3 days, over 3 days (−20%), weekly, monthly (contact). null price → "Contact us".
const tierPrices: (number | null)[] = [DAILY_RATE, OVER_3_DAYS_RATE, WEEKLY_RATE, null];
const POPULAR_INDEX = 2; // weekly is the best value
const perks = t('price.perks', { returnObjects: true }) as { title: string; body: string }[];
const faq = t('price.faq', { returnObjects: true }) as { q: string; a: string }[];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title={`${t('price.heading')} — ${t('site.name')}`}
  description={t('price.intro')}
  locale={locale}
  path={path}
  jsonLd={[...buildProductsJsonLd(), faqJsonLd]}
>
  <section class="mx-auto max-w-6xl px-5 pt-36 pb-10">
    <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('price.kicker')}</p>
    <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">{t('price.heading')}</h1>
    <p class="mt-5 max-w-2xl text-base text-(--muted) sm:text-lg">{t('price.intro')}</p>
  </section>

  <!-- Pricing tiers (4) -->
  <section class="mx-auto max-w-6xl px-5 pb-6">
    <SectionReveal class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        plans.map((plan, i) => (
          <div
            data-reveal-item
            class:list={[
              'relative flex flex-col overflow-hidden rounded-card border bg-(--card) p-6',
              i === POPULAR_INDEX ? 'border-accent' : 'border-(--line)',
            ]}
          >
            {i === POPULAR_INDEX && (
              <span class="absolute right-5 top-5 rounded-full bg-accent px-3 py-1 text-xs font-semibold text-(--color-accent-ink)">
                {t('price.best_value')}
              </span>
            )}
            <p class="font-display text-sm uppercase tracking-[0.15em] text-(--accent-text)">{plan.name}</p>
            <div class="mt-5 flex items-end gap-1.5">
              {tierPrices[i] === null ? (
                <span class="font-display text-3xl font-bold leading-none">{t('price.contact_us')}</span>
              ) : (
                <>
                  <span class="font-display text-4xl font-bold leading-none tabular-nums">{formatVnd(tierPrices[i] as number)}</span>
                  <span class="pb-0.5 text-sm text-(--muted)">{t('price.per_day')}</span>
                </>
              )}
            </div>
            <p class="mt-3 text-sm text-(--muted)">{plan.note}</p>
            <a
              href={tierPrices[i] === null ? BUSINESS.whatsapp : link('/fleet')}
              class:list={[
                'mt-6 rounded-full px-4 py-2.5 text-center text-sm font-semibold transition',
                i === POPULAR_INDEX || tierPrices[i] === null
                  ? 'bg-accent text-(--color-accent-ink) hover:brightness-110'
                  : 'border border-(--line) hover:border-accent hover:text-(--accent-text)',
              ]}
            >
              {tierPrices[i] === null ? t('price.contact_us') : t('nav.book')}
            </a>
          </div>
        ))
      }
    </SectionReveal>

    <p class="mt-6 text-sm text-(--muted)">{t('price.daily.note')}</p>
  </section>

  <!-- What every rental includes -->
  <section class="mx-auto max-w-5xl px-5 pb-14">
    <h2 class="mb-6 font-display text-2xl font-bold">{t('price.includes_heading')}</h2>
    <SectionReveal class="grid gap-5 sm:grid-cols-2">
      {
        perks.map((perk) => (
          <div data-reveal-item class="flex gap-4 rounded-card border border-(--line) p-6">
            <span class="mt-0.5 grid size-7 shrink-0 place-items-center rounded-full bg-accent text-sm text-(--color-accent-ink)">✓</span>
            <div>
              <h3 class="font-display font-bold leading-snug">{perk.title}</h3>
              <p class="mt-1 text-sm text-(--muted)">{perk.body}</p>
            </div>
          </div>
        ))
      }
    </SectionReveal>
  </section>

  <!-- payment -->
  <section class="border-y border-(--line) bg-(--card)/40">
    <div class="mx-auto flex max-w-5xl flex-col items-start gap-4 px-5 py-14 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="font-display text-2xl font-bold">{t('price.payment_heading')}</h2>
        <p class="mt-2 text-(--muted)">💵 {t('price.payment_body')}</p>
      </div>
      <a href={`tel:${BUSINESS.phone}`} class="shrink-0 rounded-full border border-(--line) px-6 py-3 font-semibold transition hover:border-accent hover:text-(--accent-text)">
        {t('business.call')} · {BUSINESS.phoneDisplay}
      </a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-5 py-20">
    <h2 class="mb-8 font-display text-3xl font-bold tracking-tight">{t('price.faq_heading')}</h2>
    <div class="divide-y divide-(--line) border-y border-(--line)">
      {
        faq.map((f) => (
          <details class="group" data-faq>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-display font-semibold">
              {f.q}
              <span class="shrink-0 text-(--accent-text) transition-transform duration-300 group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <div data-faq-body class="overflow-hidden">
              <p class="pb-5 text-(--muted)">{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </section>
</Base>
