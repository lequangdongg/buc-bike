---
import Base from '../../layouts/Base.astro';
import SectionReveal from '../SectionReveal.astro';
import PriceTable from '../PriceTable.astro';
import { useTranslations } from '../../i18n';
import { localizePath, type Locale } from '../../i18n/config';
import { buildProductsJsonLd } from '../../lib/seo';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = await useTranslations(locale);
const link = (p: string) => localizePath(p, locale);

const includes = t('price.includes', { returnObjects: true }) as string[];
const faq = t('price.faq', { returnObjects: true }) as { q: string; a: string }[];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title={`${t('price.heading')} — ${t('site.name')}`}
  description={t('price.intro')}
  locale={locale}
  path={path}
  jsonLd={[...buildProductsJsonLd(), faqJsonLd]}
>
  <section class="mx-auto max-w-6xl px-5 pt-36 pb-12">
    <p class="font-display text-sm uppercase tracking-[0.2em] text-accent">{t('price.kicker')}</p>
    <h1 class="mt-3 font-display text-5xl font-bold tracking-tight sm:text-6xl">{t('price.heading')}</h1>
    <p class="mt-5 max-w-2xl text-lg text-(--muted)">{t('price.intro')}</p>

    <p class="mt-6 inline-flex items-start gap-2 rounded-card border border-(--line) bg-(--card) px-4 py-3 text-sm text-(--muted)">
      <span aria-hidden="true">ⓘ</span>
      <span>{t('price.disclaimer')}</span>
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-16">
    <PriceTable locale={locale} />
  </section>

  <!-- includes + payment -->
  <section class="border-y border-(--line) bg-(--card)/40">
    <div class="mx-auto grid max-w-6xl gap-12 px-5 py-20 md:grid-cols-[1.3fr_1fr]">
      <div>
        <h2 class="font-display text-2xl font-bold">{t('price.includes_heading')}</h2>
        <SectionReveal class="mt-6 grid gap-3 sm:grid-cols-2">
          {
            includes.map((item) => (
              <div data-reveal-item class="flex items-center gap-3 rounded-card border border-(--line) px-4 py-3">
                <span class="grid size-7 shrink-0 place-items-center rounded-full bg-accent text-sm text-(--color-accent-ink)">✓</span>
                <span class="text-sm">{item}</span>
              </div>
            ))
          }
        </SectionReveal>
      </div>
      <div class="rounded-card border border-(--line) p-7">
        <h2 class="font-display text-2xl font-bold">{t('price.payment_heading')}</h2>
        <p class="mt-4 text-(--muted)">💵 {t('price.payment_body')}</p>
        <a href={link('/fleet')} class="mt-8 inline-block rounded-full bg-accent px-6 py-3 font-semibold text-(--color-accent-ink) transition hover:brightness-110">
          {t('hero.cta_secondary')}
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-5 py-20">
    <h2 class="mb-8 font-display text-3xl font-bold tracking-tight">{t('price.faq_heading')}</h2>
    <div class="divide-y divide-(--line) border-y border-(--line)">
      {
        faq.map((f) => (
          <details class="group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-display font-semibold">
              {f.q}
              <span class="text-accent transition group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="pb-5 text-(--muted)">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</Base>
