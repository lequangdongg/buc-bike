---
import Base from '../../layouts/Base.astro';
import SectionReveal from '../SectionReveal.astro';
import BikeCard from '../BikeCard.astro';
import { useTranslations } from '../../i18n';
import type { Locale } from '../../i18n/config';
import { BIKES } from '../../data/fleet';
import { buildProductsJsonLd } from '../../lib/seo';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = await useTranslations(locale);
---

<Base
  title={`${t('fleet.heading')} — ${t('site.name')}`}
  description={t('fleet.intro')}
  locale={locale}
  path={path}
  jsonLd={buildProductsJsonLd()}
>
  <section class="mx-auto max-w-6xl px-5 pt-36 pb-12">
    <p class="font-display text-sm uppercase tracking-[0.2em] text-accent">{t('fleet.kicker')}</p>
    <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">{t('fleet.heading')}</h1>
    <p class="mt-5 max-w-2xl text-base text-(--muted) sm:text-lg">{t('fleet.intro')}</p>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-24">
    <SectionReveal class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        BIKES.map((bike) => (
          <BikeCard
            bike={bike}
            locale={locale}
            label={t('fleet.view_detail')}
            availableLabel={t('fleet.available')}
          />
        ))
      }
    </SectionReveal>
  </section>
</Base>
