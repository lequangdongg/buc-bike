---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import SectionReveal from '../SectionReveal.astro';
import BikeCard from '../BikeCard.astro';
import HeroShowcase from '../HeroShowcase.astro';
import { useTranslations } from '../../i18n';
import { localizePath, type Locale } from '../../i18n/config';
import { BIKES } from '../../data/fleet';
import { BUSINESS } from '../../data/business';
import { WEEKLY_RATE, formatVnd } from '../../data/pricing';
import { buildLocalBusinessJsonLd } from '../../lib/seo';
import felizHero from '../../assets/feliz-lite-bright.png';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = await useTranslations(locale);
const link = (p: string) => localizePath(p, locale);

type Item = { title: string; body: string };
const features = t('features.items', { returnObjects: true }) as Item[];
const steps = t('booking.steps', { returnObjects: true }) as Item[];
const needs = t('booking.need', { returnObjects: true }) as Item[];
const advantages = t('advantages.items', { returnObjects: true }) as Item[];

const maxRange = Math.max(...BIKES.map((b) => b.rangeKm));
const advantageIcons = ['🪪', '⚡', '🌿', '💰'];
---

<Base
  title={`${t('site.name')} — ${t('hero.title_line1')} ${t('hero.title_line2')}`}
  description={t('hero.subtitle')}
  locale={locale}
  path={path}
  jsonLd={[buildLocalBusinessJsonLd()]}
>
  <!-- ░░ HERO ░░ -->
  <section class="relative flex items-center overflow-hidden py-24 md:min-h-[100svh] md:py-0">
    <!-- Feliz Lite hero subject — desktop: floating on the right -->
    <div
      class="pointer-events-none absolute inset-y-0 right-0 -z-10 hidden w-[55%] items-center justify-center md:flex"
    >
      <div class="absolute size-[82%] rounded-full bg-charge/25 blur-3xl"></div>
      <div class="absolute size-[55%] rounded-full bg-white/12 blur-2xl"></div>
      <Image src={felizHero} alt="VinFast Feliz Lite" width={760} height={760} loading="eager" class="bike-float relative h-auto w-[88%] max-w-xl object-contain brightness-110 drop-shadow-[0_25px_60px_rgba(0,0,0,0.55)]" />
    </div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-(--bg) via-(--bg)/80 to-transparent"></div>

    <!-- signature charge-arc -->
    <svg
      class="pointer-events-none absolute -right-24 top-1/2 -z-10 hidden h-[130%] -translate-y-1/2 opacity-60 md:block"
      viewBox="0 0 400 400"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="200" cy="200" r="180" stroke="var(--line)" stroke-width="1" />
      <circle
        cx="200"
        cy="200"
        r="180"
        stroke="var(--color-charge)"
        stroke-width="3"
        stroke-linecap="round"
        stroke-dasharray="1130"
        stroke-dashoffset="280"
        transform="rotate(-90 200 200)"
        opacity="0.9"
      />
    </svg>

    <div id="hero-inner" class="mx-auto w-full max-w-6xl px-5">
      <p class="font-display text-sm font-medium uppercase tracking-[0.2em] text-(--accent-text)">
        {t('hero.kicker')}
      </p>
      <h1 class="mt-5 font-display text-[clamp(2.6rem,11vw,7rem)] font-bold leading-[0.95] tracking-tight">
        {t('hero.title_line1')}<br /><span class="text-(--muted)">{t('hero.title_line2')}</span>
      </h1>
      <p class="mt-5 max-w-xl text-base text-(--muted) sm:text-lg">{t('hero.subtitle')}</p>

      <p class="mt-8 text-sm text-(--muted)">
        {t('fleet.from')}{' '}
        <span class="font-display text-lg font-bold tabular-nums text-(--accent-text)">{formatVnd(WEEKLY_RATE)}</span>{' '}
        {t('price.per_day')}
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={link('/price')}
          class="group rounded-full bg-accent px-7 py-3.5 font-semibold text-(--color-accent-ink) shadow-lg shadow-accent/25 transition hover:brightness-110 active:scale-[0.98]"
        >
          {t('hero.cta_price')}
          <span class="ml-1 inline-block transition group-hover:translate-x-0.5">→</span>
        </a>
        <a
          href="#location"
          class="rounded-full border border-(--line) px-6 py-3.5 font-semibold transition hover:border-accent hover:text-(--accent-text) active:scale-[0.98]"
        >
          {t('business.directions')}
        </a>
      </div>

      <!-- stats strip with count-up -->
      <dl class="mt-14 grid max-w-2xl grid-cols-2 gap-x-8 gap-y-6 tabular-nums sm:grid-cols-4">
        <div>
          <dt class="text-xs uppercase tracking-wider text-(--muted)">{t('stats.rating')}</dt>
          <dd class="mt-1 font-display text-3xl font-bold">
            <span data-count={BUSINESS.rating.value} data-decimals="1">0</span>
          </dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wider text-(--muted)">{t('stats.reviews')}</dt>
          <dd class="mt-1 font-display text-3xl font-bold">
            <span data-count={BUSINESS.rating.count}>0</span>+
          </dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wider text-(--muted)">{t('stats.range')}</dt>
          <dd class="mt-1 font-display text-3xl font-bold text-charge">
            <span data-count={maxRange}>0</span>
          </dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wider text-(--muted)">{t('stats.support')}</dt>
          <dd class="mt-1 font-display text-3xl font-bold">24<span class="text-(--muted)">h</span></dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ░░ FELIZ LITE SHOWCASE (pinned hotspots) ░░ -->
  <HeroShowcase locale={locale} />

  <!-- ░░ FEATURES ░░ -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="mb-12 max-w-2xl">
      <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('features.kicker')}</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">{t('features.heading')}</h2>
    </div>
    <SectionReveal class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((f) => (
          <article
            data-reveal-item
            class="rounded-card border border-(--line) bg-(--card) p-6 transition hover:border-accent"
          >
            <h3 class="font-display text-lg font-bold">{f.title}</h3>
            <p class="mt-2 text-sm text-(--muted)">{f.body}</p>
          </article>
        ))
      }
    </SectionReveal>
  </section>

  <!-- ░░ HOW TO BOOK (ordered sequence) ░░ -->
  <section class="border-y border-(--line) bg-(--card)/40">
    <div class="mx-auto max-w-6xl px-5 py-24">
      <div class="mb-12 max-w-2xl">
        <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('booking.kicker')}</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">{t('booking.heading')}</h2>
      </div>
      <SectionReveal class="grid gap-px overflow-hidden rounded-card border border-(--line) bg-(--line) sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((s, i) => (
            <div data-reveal-item class="bg-(--card) p-6">
              <span class="font-display text-4xl font-bold text-(--accent-text)">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="mt-4 font-display text-base font-bold">{s.title}</h3>
              <p class="mt-2 text-sm text-(--muted)">{s.body}</p>
            </div>
          ))
        }
      </SectionReveal>

      <SectionReveal class="mt-6 grid gap-5 sm:grid-cols-2">
        {
          needs.map((n) => (
            <div data-reveal-item class="flex gap-4 rounded-card border border-(--line) p-6">
              <span class="grid size-9 shrink-0 place-items-center rounded-full bg-accent text-(--color-accent-ink)">✓</span>
              <div>
                <h3 class="font-display text-base font-bold">{n.title}</h3>
                <p class="mt-1 text-sm text-(--muted)">{n.body}</p>
              </div>
            </div>
          ))
        }
      </SectionReveal>
    </div>
  </section>

  <!-- ░░ ADVANTAGES ░░ -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="mb-12 max-w-2xl">
      <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('advantages.kicker')}</p>
    </div>
    <SectionReveal class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        advantages.map((a, i) => (
          <article data-reveal-item class="rounded-card border border-(--line) p-6">
            <span class="text-3xl">{advantageIcons[i]}</span>
            <h3 class="mt-4 font-display text-lg font-bold">{a.title}</h3>
            <p class="mt-2 text-sm text-(--muted)">{a.body}</p>
          </article>
        ))
      }
    </SectionReveal>
  </section>

  <!-- ░░ FLEET PREVIEW ░░ -->
  <section id="fleet" class="mx-auto max-w-6xl px-5 py-12 scroll-mt-24">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('fleet.kicker')}</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">{t('fleet.heading')}</h2>
      </div>
      <a href={link('/fleet')} class="text-sm text-(--muted) transition hover:text-(--accent-text)">
        {t('fleet.view_detail')} →
      </a>
    </div>
    <SectionReveal class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        BIKES.map((bike) => (
          <BikeCard
            bike={bike}
            locale={locale}
            label={t('fleet.view_detail')}
            availableLabel={t('fleet.available')}
          />
        ))
      }
    </SectionReveal>
  </section>

  <!-- ░░ BUSINESS / LOCATION ░░ -->
  <section id="location" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-24">
    <SectionReveal class="overflow-hidden rounded-card border border-(--line) bg-(--card)">
      <div class="grid gap-10 p-8 md:grid-cols-2 md:p-12" data-reveal-item>
        <div>
          <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('business.kicker')}</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">{t('business.heading')}</h2>
          <div class="mt-6 flex items-center gap-3">
            <span class="font-display text-4xl font-bold text-(--accent-text)">
              <span data-count={BUSINESS.rating.value} data-decimals="1">0</span>
            </span>
            <a href={BUSINESS.maps} target="_blank" rel="noopener" class="text-(--muted) transition hover:text-(--fg)">
              <span class="text-(--accent-text)">★★★★★</span> · {t('business.reviews', { count: BUSINESS.rating.count })} {t('business.on_google')}
            </a>
          </div>
          <address class="mt-6 not-italic text-(--muted)">
            <p>📍 {BUSINESS.address.street}</p>
            <p>{BUSINESS.address.district} · {BUSINESS.address.city} {BUSINESS.address.postalCode}</p>
            <p class="mt-2">🕙 {t('business.open_now')}</p>
          </address>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={BUSINESS.maps} class="rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-(--color-accent-ink) transition hover:brightness-110">
              {t('business.directions')}
            </a>
            <a href={`tel:${BUSINESS.phone}`} class="rounded-full border border-(--line) px-5 py-2.5 text-sm font-semibold transition hover:border-accent hover:text-(--accent-text)">
              {t('business.call')} · {BUSINESS.phoneDisplay}
            </a>
          </div>
        </div>
        <div class="relative min-h-72 overflow-hidden rounded-card border border-(--line)">
          <iframe
            title={`${BUSINESS.name} — ${BUSINESS.address.city}`}
            src={`https://maps.google.com/maps?q=${BUSINESS.geo.lat},${BUSINESS.geo.lng}&z=16&output=embed`}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-full min-h-72 w-full border-0 grayscale-[0.2]"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </SectionReveal>
  </section>

  <script>
    import { initHeroScroll } from '../../lib/motion/heroScroll';
    document.addEventListener('astro:page-load', () => {
      const el = document.getElementById('hero-inner');
      if (el) initHeroScroll(el);
    });
  </script>
</Base>
