---
import Base from '../../layouts/Base.astro';
import SectionReveal from '../SectionReveal.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n';
import { localizePath, DEFAULT_LOCALE, type Locale } from '../../i18n/config';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = await useTranslations(locale);
const link = (p: string) => localizePath(p, locale);

const all = await getCollection('blog');
let posts = all.filter((p) => p.data.locale === locale);
if (!posts.length) posts = all.filter((p) => p.data.locale === DEFAULT_LOCALE);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const dateLocale = locale === 'vi' ? 'vi-VN' : locale;
const fmtDate = (d: Date) =>
  d.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title={`${t('blog.heading')} — ${t('site.name')}`} description={t('blog.heading')} locale={locale} path={path}>
  <section class="mx-auto max-w-5xl px-5 pt-36 pb-12">
    <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('blog.kicker')}</p>
    <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">{t('blog.heading')}</h1>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-24">
    <SectionReveal class="grid gap-5 sm:grid-cols-2">
      {
        posts.map((p) => (
          <a
            href={link(`/blog/${p.data.slug}`)}
            data-reveal-item
            class="group flex flex-col rounded-card border border-(--line) bg-(--card) p-6 transition hover:-translate-y-1 hover:border-accent"
          >
            <p class="text-xs uppercase tracking-wider text-(--muted)">{fmtDate(p.data.date)}</p>
            <h2 class="mt-3 font-display text-xl font-bold leading-tight">{p.data.title}</h2>
            <p class="mt-2 flex-1 text-sm text-(--muted)">{p.data.description}</p>
            <span class="mt-5 text-sm text-(--accent-text) transition group-hover:translate-x-0.5">{t('blog.read_more')} →</span>
          </a>
        ))
      }
    </SectionReveal>
  </section>
</Base>
