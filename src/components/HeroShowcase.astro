---
import { Image } from 'astro:assets';
import feliz from '../assets/feliz-lite-cutout.png';
import { useTranslations } from '../i18n';
import type { Locale } from '../i18n/config';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = await useTranslations(locale);
const points = t('showcase.points', { returnObjects: true }) as { title: string; body: string }[];

// Approximate hotspot positions on the Feliz Lite photo (start, trunk, brake, range, lights).
const positions = [
  { x: 54, y: 30 },
  { x: 70, y: 47 },
  { x: 30, y: 72 },
  { x: 49, y: 62 },
  { x: 40, y: 40 },
];
---

<section data-showcase class="relative h-[300vh]">
  <div data-showcase-stage class="sticky top-0 flex h-[100svh] items-center overflow-hidden">
    <div class="mx-auto grid w-full max-w-6xl items-center gap-8 px-5 md:grid-cols-2">
      <!-- bike + hotspots (transparent — bike floats on the dark section) -->
      <div class="relative mx-auto aspect-square w-full max-w-xs sm:max-w-sm md:max-w-md">
        <div class="absolute inset-[10%] rounded-full bg-charge/12 blur-3xl"></div>
        <Image src={feliz} alt="VinFast Feliz Lite" width={800} height={800} class="relative h-full w-full object-contain p-4" />
        {
          points.map((p, i) => (
            <button
              data-hotspot={i}
              type="button"
              aria-label={`${i + 1}. ${p.title}`}
              style={`left:${positions[i].x}%;top:${positions[i].y}%`}
              class="absolute z-10 -translate-x-1/2 -translate-y-1/2"
            >
              <span class="hs-num">{i + 1}</span>
            </button>
          ))
        }
      </div>

      <!-- callouts + progress -->
      <div class="relative">
        <p class="font-display text-sm uppercase tracking-[0.2em] text-(--accent-text)">{t('showcase.kicker')}</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">{t('showcase.heading')}</h2>

        <div class="hs-wrap relative mt-8 min-h-44">
          {
            points.map((p, i) => (
              <div data-callout={i} class="hs-callout">
                <span class="font-display text-4xl font-bold tabular-nums text-(--accent-text)">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="mt-2 font-display text-xl font-bold">{p.title}</h3>
                <p class="mt-1 text-(--muted)">{p.body}</p>
              </div>
            ))
          }
        </div>

        <div class="mt-8 flex gap-2">
          {points.map((_, i) => <span data-dot={i} class="hs-progress"></span>)}
        </div>
        <p class="hs-hint mt-6 text-xs uppercase tracking-wider text-(--muted)">{t('showcase.scroll_hint')} ↓</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hs-num {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 9999px;
    border: 2px solid var(--color-accent);
    background: color-mix(in srgb, var(--color-base, #0b0e0f) 70%, transparent);
    backdrop-filter: blur(2px);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    opacity: 0.72;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.45);
    transition: transform 0.3s ease, opacity 0.3s ease, background 0.3s ease, color 0.3s ease;
  }
  [data-hotspot] {
    position: absolute;
    cursor: default;
  }
  [data-hotspot]::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 9999px;
    border: 2px solid var(--color-accent);
    opacity: 0;
  }
  [data-hotspot][data-active='true'] .hs-num {
    opacity: 1;
    transform: scale(1.25);
    background: var(--color-accent);
    color: var(--color-accent-ink);
  }
  [data-hotspot][data-active='true']::after {
    animation: hs-ping 1.5s ease-out infinite;
  }
  @keyframes hs-ping {
    0% { opacity: 0.7; transform: scale(0.7); }
    100% { opacity: 0; transform: scale(1.8); }
  }

  .hs-callout {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }
  .hs-callout[data-active='true'] {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .hs-progress {
    height: 6px;
    width: 22px;
    border-radius: 9999px;
    background: var(--line);
    transition: background 0.3s ease, width 0.3s ease;
  }
  .hs-progress[data-active='true'] {
    background: var(--color-accent);
    width: 34px;
  }

  /* Mobile + reduced-motion: no pin/scroll-jack — stack the image and list
     every callout in normal flow (mobile-first). */
  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    [data-showcase] { height: auto !important; }
    [data-showcase-stage] {
      position: static !important;
      height: auto !important;
      padding: 1rem 0 2rem;
    }
    .hs-wrap { min-height: 0 !important; }
    .hs-callout {
      position: static;
      opacity: 1;
      transform: none;
      margin-bottom: 1.75rem;
    }
    .hs-callout:last-child { margin-bottom: 0; }
    .hs-num { opacity: 1; }
    .hs-hint { display: none; }
  }
</style>
