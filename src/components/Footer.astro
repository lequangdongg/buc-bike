---
import { useTranslations } from '../i18n';
import { localizePath, type Locale } from '../i18n/config';
import { BUSINESS } from '../data/business';

interface Props {
  locale: Locale;
  path: string;
}
const { locale } = Astro.props;
const t = await useTranslations(locale);
const link = (p: string) => localizePath(p, locale);
const year = 2026;
---

<footer class="mt-32 border-t border-(--line)">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-16 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <a href={link('/')} class="font-display text-2xl font-bold tracking-tight">
        Buck<span class="text-accent">Bike</span>
      </a>
      <p class="mt-3 max-w-xs text-sm text-(--muted)">{t('site.tagline')} · {BUSINESS.address.city}</p>
      <div class="mt-5 flex gap-3">
        <a href={BUSINESS.socials.facebook} aria-label="Facebook" class="grid size-9 place-items-center rounded-full border border-(--line) transition hover:border-accent hover:text-accent">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3V6h-3c-2 0-3 1-3 3v2H9v3h2v7h3v-7h2.5l.5-3H14V9z" /></svg>
        </a>
        <a href={BUSINESS.socials.instagram} aria-label="Instagram" class="grid size-9 place-items-center rounded-full border border-(--line) transition hover:border-accent hover:text-accent">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" /></svg>
        </a>
        <a href={BUSINESS.socials.x} aria-label="X" class="grid size-9 place-items-center rounded-full border border-(--line) transition hover:border-accent hover:text-accent">
          <svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h3l-7 8 8 12h-6l-5-7-5 7H-2l8-9L-2 2h6l4 6 6-6z" transform="translate(2 0)" /></svg>
        </a>
      </div>
    </div>

    <nav class="text-sm">
      <p class="mb-3 font-display font-semibold">{t('nav.home')}</p>
      <ul class="space-y-2 text-(--muted)">
        <li><a class="transition hover:text-(--fg)" href={link('/fleet')}>{t('nav.fleet')}</a></li>
        <li><a class="transition hover:text-(--fg)" href={link('/price')}>{t('nav.price')}</a></li>
        <li><a class="transition hover:text-(--fg)" href={BUSINESS.maps}>{t('business.directions')}</a></li>
      </ul>
    </nav>

    <address class="text-sm not-italic text-(--muted)">
      <p class="mb-3 font-display font-semibold text-(--fg)">{BUSINESS.address.city}</p>
      <p>{BUSINESS.address.street}</p>
      <p>{BUSINESS.address.district} · {BUSINESS.address.postalCode}</p>
      <p class="mt-3">
        <a class="transition hover:text-accent" href={`tel:${BUSINESS.phone}`}>{BUSINESS.phoneDisplay}</a>
      </p>
    </address>
  </div>

  <div class="border-t border-(--line)">
    <div class="mx-auto flex max-w-6xl flex-col gap-1 px-5 py-6 text-xs text-(--muted) sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {BUSINESS.name}. {t('footer.rights')}</p>
      <p>{t('footer.made_with')}</p>
    </div>
  </div>
</footer>
