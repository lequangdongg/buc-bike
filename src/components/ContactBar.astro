const channels = [
  { id: 'zalo', label: 'Zalo', href: `https://zalo.me/${phoneDigits}`, appOnly: false, viewBox: '0 0 50 50', svg: ZALO },
  { id: 'whatsapp', label: 'WhatsApp', href: `https://wa.me/${phoneDigits}`, appOnly: false, viewBox: '0 0 24 24', svg: WHATSAPP },
  { id: 'wechat', label: 'WeChat', href: `weixin://dl/chat?phone=${phone}`, appOnly: true, viewBox: '0 0 24 24', svg: WECHAT },
  { id: 'kakao', label: 'KakaoTalk', href: `kakaotalk://launch?phone=${phone}`, appOnly: true, viewBox: '0 0 24 24', svg: KAKAO },
];
---

<nav
  id="contact-bar"
  aria-label="Contact channels"
  class="fixed inset-x-0 bottom-0 z-30 flex justify-center border-t border-(--line) bg-(--bg)/90 backdrop-blur-xl pb-[env(safe-area-inset-bottom)] md:inset-x-auto md:bottom-auto md:right-4 md:top-1/2 md:-translate-y-1/2 md:flex-col md:rounded-full md:border md:bg-(--card)/90 md:p-1.5 md:shadow-xl md:shadow-black/30"
>
  {
    channels.map((c, i) => (
      <a
        href={c.href}
        target={c.appOnly ? undefined : '_blank'}
        rel="noopener"
        data-channel={c.id}
        data-app-only={c.appOnly ? 'true' : undefined}
        data-phone={BUSINESS.phoneDisplay}
        aria-label={c.label}
        class:list={[
          'group relative flex flex-1 flex-col items-center justify-center gap-1 py-2.5 text-(--muted) transition hover:text-(--fg)',
          'md:size-12 md:flex-none md:rounded-full md:py-0 md:hover:bg-(--card-2)',
          i > 0 ? 'border-l border-(--line) md:border-l-0' : '',
        ]}
      >
        <span class="grid size-7 place-items-center md:size-6">
          <svg viewBox={c.viewBox} class="size-full" aria-hidden="true" set:html={c.svg} />
        </span>
        <span class="text-[0.65rem] font-medium md:hidden">{c.label}</span>
        <span class="pointer-events-none absolute right-full mr-3 hidden whitespace-nowrap rounded-md bg-(--card) px-2 py-1 text-xs opacity-0 shadow-lg transition group-hover:opacity-100 md:block">
          {c.label}
        </span>
      </a>
    ))
  }
</nav>

<div
  id="contact-toast"
  role="status"
  aria-live="polite"
  class="pointer-events-none fixed bottom-24 left-1/2 z-50 -translate-x-1/2 rounded-full bg-(--fg) px-4 py-2 text-sm font-medium text-(--bg) opacity-0 shadow-xl transition-opacity duration-300 md:bottom-8"
>
</div>

<script>
  import { animate } from 'motion';
  import { prefersReducedMotion } from '../lib/motion/prefersReducedMotion';

  function initContactBar() {
    const bar = document.getElementById('contact-bar');
    const toast = document.getElementById('contact-toast');
    if (!bar) return;

    if (!prefersReducedMotion() && !bar.dataset.shown) {
      bar.dataset.shown = 'true';
      const fromMobile = window.matchMedia('(max-width: 767px)').matches;
      animate(
        bar,
        fromMobile
          ? { transform: ['translateY(100%)', 'translateY(0)'] }
          : { opacity: [0, 1], transform: ['translateX(20px)', 'translateX(0)'] },
        { duration: 0.5, delay: 0.4, ease: [0.16, 1, 0.3, 1] },
      );
    }

    let toastTimer: ReturnType<typeof setTimeout> | undefined;
    const showToast = (msg: string) => {
      if (!toast) return;
      toast.textContent = msg;
      toast.style.opacity = '1';
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => (toast.style.opacity = '0'), 2400);
    };

    bar.querySelectorAll<HTMLAnchorElement>('[data-app-only="true"]').forEach((link) => {
      link.addEventListener('click', (event) => {
        const isTouch = window.matchMedia('(pointer: coarse)').matches;
        if (isTouch) return; // let the deep link open the app on phones
        event.preventDefault();
        const phone = link.dataset.phone || '';
        const channel = link.dataset.channel || '';
        const label = channel === 'wechat' ? 'WeChat' : 'KakaoTalk';
        navigator.clipboard?.writeText(phone).then(
          () => showToast(`${label}: ${phone} copied`),
          () => showToast(`${label}: ${phone}`),
        );
      });
    });
  }

  document.addEventListener('astro:page-load', initContactBar);
</script>
