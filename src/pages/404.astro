---
import Base from '../layouts/Base.astro';
import { useTranslations } from '../i18n';
import { localizePath } from '../i18n/config';

const locale = 'en' as const;
const t = await useTranslations(locale);
const link = (p: string) => localizePath(p, locale);
---

<Base
  title="Page not found — BuckBike"
  description="The page you are looking for doesn't exist."
  locale={locale}
  path="/404"
>
  <section class="relative flex min-h-[80svh] items-center overflow-hidden">
    <svg
      class="pointer-events-none absolute -right-24 top-1/2 -z-10 hidden h-[120%] -translate-y-1/2 opacity-50 md:block"
      viewBox="0 0 400 400"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="200" cy="200" r="180" stroke="var(--color-charge)" stroke-width="3" stroke-linecap="round" stroke-dasharray="1130" stroke-dashoffset="380" transform="rotate(-90 200 200)" />
    </svg>

    <div class="mx-auto w-full max-w-3xl px-5 text-center">
      <p class="font-display text-[clamp(4rem,18vw,9rem)] font-bold leading-none tracking-tight text-(--accent-text)">404</p>
      <h1 class="mt-2 font-display text-3xl font-bold tracking-tight sm:text-4xl">This page took a wrong turn</h1>
      <p class="mx-auto mt-4 max-w-md text-(--muted)">
        The page you're after doesn't exist or has moved. Let's get you back on the road.
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        <a href={link('/')} class="rounded-full bg-accent px-6 py-3 font-semibold text-(--color-accent-ink) transition hover:brightness-110 active:scale-[0.98]">
          {t('nav.home')}
        </a>
        <a href={link('/fleet')} class="rounded-full border border-(--line) px-6 py-3 font-semibold transition hover:border-accent hover:text-(--accent-text) active:scale-[0.98]">
          {t('nav.fleet')}
        </a>
        <a href={link('/price')} class="rounded-full border border-(--line) px-6 py-3 font-semibold transition hover:border-accent hover:text-(--accent-text) active:scale-[0.98]">
          {t('nav.price')}
        </a>
      </div>
    </div>
  </section>
</Base>
