---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import ContactBar from '../components/ContactBar.astro';
import Seo from '../components/Seo.astro';
import { useTranslations } from '../i18n';
import type { Locale } from '../i18n/config';
import { pageFade } from '../lib/motion/pageTransition';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  path: string;
  jsonLd?: object[];
}

const { title, description, locale, path, jsonLd } = Astro.props;
const t = await useTranslations(locale);
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!--
      Language preference redirect (runs before paint, static-site friendly).
      Priority: explicit localStorage `lang` → navigator.language guess → EN default.
      Mirrors src/i18n/config.ts (LOCALES / DEFAULT_LOCALE). Bots are skipped.
    -->
    <script is:inline>
      (function () {
        try {
          var PREFIXED = ['vi', 'ru', 'ja', 'ko', 'zh']; // en is the unprefixed default
          var ua = navigator.userAgent || '';
          if (/(bot|crawl|spider|slurp|bingpreview|mediapartners|facebookexternalhit|embedly|pinterest|slackbot|whatsapp|telegram)/i.test(ua)) return;

          var path = location.pathname;
          var seg = path.split('/').filter(Boolean)[0];
          var current = PREFIXED.indexOf(seg) > -1 ? seg : 'en';

          var stored = null;
          try { stored = localStorage.getItem('lang'); } catch (e) {}

          var target = null;
          if (stored === 'en' || PREFIXED.indexOf(stored) > -1) {
            target = stored; // explicit choice wins
          } else {
            var base = (navigator.language || '').toLowerCase().split('-')[0];
            if (base === 'zh') target = 'zh';
            else if (PREFIXED.indexOf(base) > -1) target = base;
          }

          if (!target || target === current) return;

          var rest = current === 'en' ? path : path.replace('/' + current, '') || '/';
          if (!rest) rest = '/';
          var dest = target === 'en' ? rest : '/' + target + (rest === '/' ? '/' : rest);
          location.replace(dest + location.search + location.hash);
        } catch (e) {}
      })();
    </script>
    <!-- Apply saved theme before paint to avoid a flash. -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>
    <Seo title={title} description={description} locale={locale} path={path} jsonLd={jsonLd} />
    <ClientRouter />
  </head>
  <body class="min-h-dvh bg-(--bg) text-(--fg) antialiased pb-[68px] md:pb-0">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-(--color-accent-ink)"
    >
      {t('a11y.skip')}
    </a>
    <ScrollProgress />
    <Header locale={locale} path={path} />
    <main id="main" transition:animate={pageFade}>
      <slot />
    </main>
    <Footer locale={locale} path={path} />
    <ContactBar />

    <script>
      import { initReveal } from '../lib/motion/reveal';
      import { initParallax } from '../lib/motion/parallax';
      import { initCountUp } from '../lib/motion/countUp';
      import { initScrollHideHeader } from '../lib/motion/scrollHideHeader';
      import { initScrollProgress } from '../lib/motion/scrollProgress';
      import { initMobileMenu } from '../lib/motion/mobileMenu';
      import { initLangSwitcher, initFaqAccordion } from '../lib/motion/disclosure';

      let cleanups: Array<VoidFunction | undefined> = [];

      function teardown() {
        cleanups.forEach((stop) => stop?.());
        cleanups = [];
      }

      function boot() {
        teardown();
        cleanups.push(initReveal(), initParallax(), initCountUp(), initMobileMenu(), initLangSwitcher());
        initFaqAccordion();
        const header = document.getElementById('site-header');
        if (header) cleanups.push(initScrollHideHeader(header));
      }

      // Per-navigation: (re)wire scroll-driven + in-view animations.
      document.addEventListener('astro:page-load', boot);
      document.addEventListener('astro:before-swap', teardown);

      // One-time: theme toggle (delegated) + persistent progress bar.
      const w = window as unknown as { __bkGlobalInit?: boolean };
      if (!w.__bkGlobalInit) {
        w.__bkGlobalInit = true;

        document.addEventListener('click', (event) => {
          const el = event.target as HTMLElement;

          const toggle = el?.closest('#theme-toggle');
          if (toggle) {
            const isLight = document.documentElement.classList.toggle('light');
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
            return;
          }

          // Persist an explicit language choice so it survives across visits.
          const langLink = el?.closest<HTMLElement>('[data-lang-link]');
          if (langLink) {
            try {
              localStorage.setItem('lang', langLink.dataset.langLink || 'en');
            } catch (e) {
              /* ignore storage failures */
            }
          }
        });

        const bar = document.getElementById('scroll-progress');
        if (bar) initScrollProgress(bar);
      }
    </script>
  </body>
</html>
